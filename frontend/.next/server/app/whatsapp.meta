{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/whatsapp/layout,_N_T_/whatsapp/page,_N_T_/whatsapp"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/whatsapp/__PAGE__",
    "/whatsapp",
    "/_index",
    "/_head"
  ]
}